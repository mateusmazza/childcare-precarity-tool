# Firebase configuration — create a free project at https://console.firebase.google.com
# See README.md for step-by-step setup instructions.
#
# Note: Firebase web config is public by design (security comes from Firestore rules).
# The values below are only needed if you fork this repo and create your own Firebase
# project. The default firebase.js already has the Caremometer project config hardcoded.

VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id
